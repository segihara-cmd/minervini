{
  "buildCommand": "pip install yfinance pandas numpy requests -q && python generate_dashboard.py",
  "outputDirectory": "docs",
  "rewrites": [
    { "source": "/api/dashboard", "destination": "/api/dashboard.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/data.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
